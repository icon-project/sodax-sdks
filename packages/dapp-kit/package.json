{
  "name": "@sodax/dapp-kit",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "version": "0.0.1-rc.4",
  "description": "React hooks for building dApps on the SODAX cross-chain DeFi platform",
  "keywords": ["sodax", "dapp-kit", "react", "react-query", "hooks", "defi"],
  "homepage": "https://github.com/icon-project/sodax-sdks/tree/main/packages/dapp-kit",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-sdks/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": ["dist", "src"],
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-sdks"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch ./src",
    "test": "vitest run",
    "prepublishOnly": "tsup",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf .turbo",
    "pretty": "biome format . --write",
    "checkTs": "tsc --noEmit",
    "check:knip": "knip",
    "lint": "biome lint . --write"
  },
  "dependencies": {
    "@sodax/sdk": "workspace:*",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "knip": "catalog:",
    "tslib": "^2.8.1",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "5.x",
    "react": ">=18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  }
}
