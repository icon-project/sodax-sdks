{
  "name": "@sodax/sdk",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "2.0.0-rc.3",
  "license": "MIT",
  "description": "Sodax SDK",
  "keywords": ["sodax", "sdk", "frontend", "interface"],
  "homepage": "https://github.com/icon-project/sodax-sdks/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-sdks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-sdks"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "files": ["dist", "!dist/**/*.map"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude ./src/e2e-tests",
    "test-e2e": "vitest run ./src/e2e-tests",
    "coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "ci": "pnpm run pretty && pnpm run build && pnpm run test",
    "checkTs": "tsc --noEmit",
    "pretty": "biome format . --write",
    "lint": "biome lint . --write",
    "size:check": "node ./scripts/size-check.mjs",
    "check-exports": "attw --pack",
    "check:circular-deps": "madge --circular --exclude 'types/dist' $(find ./src -name '*.ts')",
    "check:knip": "knip",
    "prepublishOnly": "pnpm run ci",
    "local-release": "changeset version && changeset publish",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .turbo"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@coral-xyz/anchor": "0.30.1",
    "@injectivelabs/networks": "catalog:",
    "@injectivelabs/sdk-ts": "catalog:",
    "@mysten/sui": "catalog:",
    "@pancakeswap/infinity-sdk": "^1.0.0",
    "@pancakeswap/swap-sdk-core": "^1.5.1",
    "@pancakeswap/v3-sdk": "^3.9.7",
    "@sodax/types": "workspace:*",
    "@solana/spl-token": "catalog:",
    "@solana/web3.js": "catalog:",
    "@stacks/network": "catalog:",
    "@stacks/transactions": "catalog:",
    "@stellar/stellar-sdk": "catalog:",
    "bignumber.js": "catalog:",
    "bitcoinjs-lib": "^6.1.5",
    "bn.js": "^5.2.1",
    "icon-sdk-js": "catalog:",
    "near-api-js": "catalog:",
    "rlp": "3.0.0",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/bn.js": "^5.1.6",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "knip": "catalog:",
    "madge": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
