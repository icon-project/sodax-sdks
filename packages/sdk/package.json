{
  "name": "@sodax/sdk",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1-rc.5",
  "license": "MIT",
  "description": "Sodax SDK",
  "keywords": [
    "sodax",
    "sdk",
    "frontend",
    "interface"
  ],
  "homepage": "https://github.com/icon-project/sodax-frontend/tree/main/packages/sdk",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-frontend/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-frontend"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude ./src/e2e-tests",
    "test-e2e": "vitest run ./src/e2e-tests",
    "coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "ci": "pnpm run pretty && pnpm run build && pnpm run test",
    "checkTs": "tsc --noEmit",
    "pretty": "biome format . --write",
    "lint": "biome lint . --write",
    "check-exports": "attw $(pnpm pack) --ignore-rules=cjs-resolves-to-esm",
    "prepublishOnly": "pnpm run ci",
    "local-release": "changeset version && changeset publish",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .turbo"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@coral-xyz/anchor": "0.30.1",
    "@injectivelabs/core-proto-ts": "1.16.5",
    "@injectivelabs/networks": "catalog:",
    "@injectivelabs/sdk-ts": "catalog:",
    "@mysten/sui": "catalog:",
    "@ordjs/runestone": "^1.6.0",
    "@sodax/types": "workspace:*",
    "@solana/spl-token": "catalog:",
    "@solana/web3.js": "catalog:",
    "@stellar/stellar-sdk": "catalog:",
    "bignumber.js": "catalog:",
    "bitcoinjs-lib": "^6.1.5",
    "bn.js": "^5.2.1",
    "ecpair": "^2.0.1",
    "icon-sdk-js": "catalog:",
    "near-api-js": "catalog:",
    "rlp": "3.0.0",
    "runelib": "^1.0.7",
    "tiny-invariant": "1.3.3",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/bn.js": "^5.1.6",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
