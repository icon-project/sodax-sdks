{
  "name": "@sodax/wallet-sdk-react",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "version": "2.0.0-rc.3",
  "description": "Wallet SDK of Sodax",
  "keywords": ["sodax", "wallet", "sdk", "react", "multichain", "web3"],
  "homepage": "https://github.com/icon-project/sodax-sdks/tree/main/packages/wallet-sdk-react",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-sdks/issues"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.12.0"
  },
  "files": ["dist", "!dist/**/*.map", "README.md", "docs"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./xchains/*": {
      "types": "./dist/xchains/*/index.d.ts",
      "import": "./dist/xchains/*/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "xchains/*": ["./dist/xchains/*/index.d.ts"]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-sdks"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 tsup",
    "dev": "tsup --watch ./src",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf .turbo",
    "pretty": "biome format . --write",
    "checkTs": "tsc --noEmit",
    "check-exports": "attw --pack --profile esm-only",
    "test": "vitest run",
    "check:knip": "knip",
    "lint": "biome lint . --write"
  },
  "dependencies": {
    "@stacks/connect": "catalog:",
    "@stacks/network": "catalog:",
    "@stacks/transactions": "catalog:",
    "@creit.tech/stellar-wallets-kit": "^1.7.5",
    "@hot-labs/near-connect": "0.10.0",
    "@injectivelabs/networks": "catalog:",
    "@injectivelabs/sdk-ts": "catalog:",
    "@injectivelabs/ts-types": "catalog:",
    "@injectivelabs/wallet-base": "catalog:",
    "@injectivelabs/wallet-core": "catalog:",
    "@injectivelabs/wallet-cosmos": "catalog:",
    "@injectivelabs/wallet-strategy": "catalog:",
    "@mysten/dapp-kit": "catalog:",
    "@mysten/sui": "catalog:",
    "near-api-js": "catalog:",
    "@sodax/types": "workspace:*",
    "@sodax/wallet-sdk-core": "workspace:*",
    "@solana/spl-token": "catalog:",
    "@solana/wallet-adapter-react": "0.15.35",
    "@solana/web3.js": "catalog:",
    "@stellar/stellar-sdk": "catalog:",
    "icon-sdk-js": "catalog:",
    "immer": "10.1.1",
    "sats-connect": "^4.2.1",
    "viem": "catalog:",
    "wagmi": "catalog:",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "happy-dom": "^20.8.9",
    "knip": "catalog:",
    "react-dom": "19.1.4",
    "tslib": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "5.x",
    "react": ">=19"
  }
}
