{
  "name": "@sodax/types",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "2.0.0-rc.1",
  "description": "Sodax Common Types",
  "main": "dist/index.js",
  "homepage": "https://github.com/icon-project/sodax-sdks/tree/main/packages/types",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-sdks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-sdks"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": ["dist"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dex": {
      "types": "./dist/dex.d.ts",
      "default": "./dist/dex.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "ci": "pnpm run pretty && pnpm run build && pnpm run test",
    "checkTs": "tsc",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "pretty": "biome format . --write",
    "lint": "biome lint . --write",
    "check-exports": "attw $(pnpm pack) --ignore-rules=cjs-resolves-to-esm",
    "check:circular-deps": "madge --circular $(find ./src -name '*.ts')",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "madge": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
