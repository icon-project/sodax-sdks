{
  "name": "@sodax/wallet-sdk-core",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1-rc.5",
  "license": "MIT",
  "description": "Sodax Wallet SDK Core",
  "keywords": ["sodax", "wallet", "sdk", "frontend", "interface"],
  "homepage": "https://github.com/icon-project/sodax-sdks/tree/main/packages/wallet-sdk-core",
  "bugs": {
    "url": "https://github.com/icon-project/sodax-sdks/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icon-project/sodax-sdks"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "files": ["dist", "!dist/**/*.map"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude ./src/tests/e2e",
    "test-e2e": "vitest run ./src/tests/e2e",
    "coverage": "vitest run --coverage",
    "dev": "tsup --watch",
    "ci": "pnpm run pretty && pnpm run build && pnpm run test",
    "checkTs": "tsc --noEmit",
    "pretty": "biome format . --write",
    "lint": "biome lint . --write",
    "check-exports": "attw --pack",
    "check:knip": "knip",
    "prepublishOnly": "pnpm run ci",
    "local-release": "changeset version && changeset publish",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .turbo"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@hot-labs/near-connect": "0.10.0",
    "@injectivelabs/networks": "catalog:",
    "@injectivelabs/sdk-ts": "catalog:",
    "@injectivelabs/ts-types": "catalog:",
    "@injectivelabs/wallet-core": "catalog:",
    "@mysten/sui": "catalog:",
    "@mysten/wallet-standard": "catalog:",
    "@sodax/types": "workspace:*",
    "@solana/spl-token": "catalog:",
    "@solana/wallet-adapter-base": "catalog:",
    "@solana/web3.js": "catalog:",
    "@stellar/stellar-sdk": "catalog:",
    "@provablehq/aleo-types": "catalog:",
    "@provablehq/aleo-wallet-standard": "catalog:",
    "@provablehq/sdk": "catalog:",
    "@stacks/connect": "catalog:",
    "@stacks/transactions": "catalog:",
    "@stacks/network": "catalog:",
    "bip322-js": "^3.0.0",
    "bitcoinjs-lib": "^6.1.5",
    "ecpair": "^2.0.1",
    "icon-sdk-js": "catalog:",
    "near-api-js": "catalog:",
    "secp256k1": "^5.0.1",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/secp256k1": "^4.0.7",
    "@vitest/coverage-v8": "catalog:",
    "knip": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
