{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": "//",
  "files": {},
  "linter": {
    "rules": {
      "style": {
        "noUselessElse": "off",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noFallthroughSwitchClause": "error"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      },
      "correctness": {
        "noUnusedFunctionParameters": "off"
      }
    },
    "includes": ["**"]
  }
}
