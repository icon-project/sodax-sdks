{
  "name": "sodax-sdks",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build --filter=!./apps/node",
    "build:packages": "turbo run build:packages",
    "dev": "turbo run dev",
    "dev:demo": "turbo run dev --filter=demo",
    "pretty": "turbo run pretty --filter=!./apps/node",
    "lint": "turbo run lint --filter=!./apps/node",
    "lint:packages": "turbo run lint:packages",
    "checkTs": "turbo run checkTs --filter=!./apps/node",
    "checkTs:packages": "turbo run checkTs:packages",
    "test": "turbo run test --filter=!./apps/node",
    "test:packages": "turbo run test:packages",
    "check:circular-deps": "turbo run check:circular-deps",
    "check:circular-deps:packages": "turbo run check:circular-deps:packages",
    "check:ai": "turbo run check:ai",
    "check:knip": "turbo run check:knip",
    "clean": "turbo clean && rm -rf node_modules dist .turbo && rm -rf apps/*/node_modules apps/*/dist apps/*/.turbo && rm -rf packages/*/node_modules packages/*/dist packages/*/.turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "turbo": "^2.4.0"
  },
  "commitlint": {
    "extends": ["@commitlint/config-conventional"]
  },
  "pnpm": {
    "overrides": {
      "@hpke/core": ">=1.8.0",
      "valibot": ">=1.2.0",
      "axios": "1.13.2"
    }
  }
}
