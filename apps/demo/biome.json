{
  "root": false,
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": "//",
  "files": {
    "includes": ["!**/.next", "!src/components/ui"]
  },
  "linter": {
    "rules": {
      "style": {
        "noUselessElse": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noFallthroughSwitchClause": "error"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      }
    }
  }
}
